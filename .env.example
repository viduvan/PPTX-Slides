# ═══════════════════════════════════════════════════════════
# PPTX-Slides Multi-Agent — Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── Database (shared between n8n and pptx-slides) ──
DB_POSTGRESDB_DATABASE=pptx_slides
DB_POSTGRESDB_USER=pptx
DB_POSTGRESDB_PASSWORD=your_secure_password_here

# ── Redis ──
REDIS_PASSWORD=your_redis_password_here

# ── n8n ──
N8N_WORKER_REPLICAS=3
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_n8n_password

# ── Image APIs (used by Designer agent) ──
PIXABAY_API_KEY=your_pixabay_api_key

# ── LLM API Keys (configured on n8n UI, NOT used by agents) ──
# These are for reference only. Set them as n8n credentials via UI.
# GEMINI_API_KEY=AIzaSy...
# OPENAI_API_KEY=sk-proj-...
# ANTHROPIC_API_KEY=sk-ant-...
